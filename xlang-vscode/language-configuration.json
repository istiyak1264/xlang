{
    "comments": {
        "line": "//",
        "block": ["/*", "*/"]
    },
    "brackets": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"]
    ],
    "autoClosingPairs": [
        { "open": "{",  "close": "}" },
        { "open": "[",  "close": "]" },
        { "open": "(",  "close": ")" },
        { "open": "\"", "close": "\"", "notIn": ["string"] },
        { "open": "/*", "close": "*/" }
    ],
    "surroundingPairs": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"],
        ["\"", "\""]
    ],
    "folding": {
        "markers": {
            "start": "^\\s*//\\s*#region\\b",
            "end":   "^\\s*//\\s*#endregion\\b"
        }
    },
    "indentationRules": {
        "increaseIndentPattern": "^.*:\\s*$",
        "decreaseIndentPattern": "^\\s*(else\\b|else\\s+if\\b)"
    },
    "wordPattern": "(-?\\d*\\.\\d\\w*)|([^\\`\\~\\!\\@\\#\\%\\^\\&\\*\\(\\)\\-\\=\\+\\[\\{\\]\\}\\\\\\|\\;\\:\\'\\\"\\,\\.\\<\\>\\/\\?\\s]+)"
}