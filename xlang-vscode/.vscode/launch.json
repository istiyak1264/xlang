{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "XLang: Compile & Run (F5)",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "/bin/bash",
            "runtimeArgs": [
                "-c",
                "xlangc '${file}' -o '${fileDirname}/${fileBasenameNoExtension}' && '${fileDirname}/${fileBasenameNoExtension}'"
            ],
            "console": "integratedTerminal",
            "preLaunchTask": "",
            "when": "resourceLangId == xlang"
        },
        {
            "name": "XLang: Debug with GDB",
            "type": "cppdbg",
            "request": "launch",
            "program": "${fileDirname}/${fileBasenameNoExtension}",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${fileDirname}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "preLaunchTask": "xlang: compile",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "XLang Extension: Debug (Dev)",
            "type": "extensionHost",
            "request": "launch",
            "runtimeExecutable": "${execPath}",
            "args": ["--extensionDevelopmentPath=${workspaceFolder}/xlang-vscode"],
            "outFiles": ["${workspaceFolder}/xlang-vscode/extension.js"]
        }
    ]
}