{
    "files.associations": {
        "*.x":     "xlang",
        "*.xl":    "xlang",
        "*.xlang": "xlang"
    },
    "[xlang]": {
        "editor.tabSize": 4,
        "editor.insertSpaces": true,
        "editor.detectIndentation": false,
        "editor.formatOnSave": true,
        "editor.rulers": [80, 120],
        "editor.wordWrap": "off",
        "files.encoding": "utf8",
        "files.eol": "\n"
    },
    "xlang.compilerPath": "xlangc",
    "xlang.compilerArgs": [],
    "xlang.runInTerminal": true,
    "xlang.formatOnSave": true,
    "xlang.lintOnSave": true,
    "xlang.enableIntelliSense": true,

    "code-runner.executorMap": {
        "xlang": "cd $dir && xlangc $fileName -o $fileNameWithoutExt && ./$fileNameWithoutExt"
    },
    "code-runner.runInTerminal": true,
    "code-runner.saveFileBeforeRun": true,

    "terminal.integrated.env.linux": {
        "PATH": "/usr/local/bin:${env:PATH}"
    },
    "terminal.integrated.env.osx": {
        "PATH": "/usr/local/bin:${env:PATH}"
    }
}