{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "xlang: compile",
            "type": "shell",
            "command": "xlangc",
            "args": [
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": {
                "owner": "xlang",
                "pattern": {
                    "regexp": "^\\[Error\\] line (\\d+): (.*)$",
                    "line": 1,
                    "message": 2
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            }
        },
        {
            "label": "xlang: run",
            "type": "shell",
            "command": "${fileDirname}/${fileBasenameNoExtension}",
            "dependsOn": ["xlang: compile"],
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "xlang: compile and run",
            "type": "shell",
            "command": "xlangc ${file} -o ${fileDirname}/${fileBasenameNoExtension} && ${fileDirname}/${fileBasenameNoExtension}",
            "group": "none",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            }
        },
        {
            "label": "xlang: clean",
            "type": "shell",
            "command": "rm",
            "args": ["-f", "${fileDirname}/${fileBasenameNoExtension}"],
            "problemMatcher": []
        },
        {
            "label": "xlang: build project (make)",
            "type": "shell",
            "command": "make",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        }
    ]
}