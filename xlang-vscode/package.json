{
    "name": "xlang",
    "displayName": "XLang Language Support",
    "description": "Complete XLang language support with compilation and IntelliSense",
    "version": "1.0.1",
    "publisher": "istiyak1264",
    "author": {
        "name": "Istiyak Ahmed",
        "email": "iamistiyakooo@gmail.com"
    },
    "license": "MIT",
    "homepage": "https://github.com/istiyak1264/xlang",
    "repository": {
        "type": "git",
        "url": "https://github.com/istiyak1264/xlang"
    },
    "icon": "icons/icon.png",
    "galleryBanner": {
        "color": "#1e1e1e",
        "theme": "dark"
    },
    "categories": [
        "Programming Languages",
        "Linters",
        "Formatters"
    ],
    "keywords": [
        "xlang",
        "compiler",
        "language",
        "programming",
        "c-like"
    ],
    "engines": {
        "vscode": "^1.60.0"
    },
    "activationEvents": [
        "onLanguage:xlang"
    ],
    "main": "./extension.js",
    "contributes": {
        "languages": [
            {
                "id": "xlang",
                "aliases": ["XLang", "xlang"],
                "extensions": [".xlang", ".xl", ".x"],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "xlang",
                "scopeName": "source.xlang",
                "path": "./syntaxes/xlang.tmLanguage.json"
            }
        ],
        "snippets": [
            {
                "language": "xlang",
                "path": "./snippets/xlang.json"
            }
        ],
        "commands": [
            {
                "command": "xlang.compile",
                "title": "XLang: Compile Current File",
                "category": "XLang"
            },
            {
                "command": "xlang.run",
                "title": "XLang: Run Current File",
                "category": "XLang"
            },
            {
                "command": "xlang.compileRun",
                "title": "XLang: Compile and Run",
                "category": "XLang"
            }
        ],
        "keybindings": [
            {
                "command": "xlang.compile",
                "key": "ctrl+shift+b",
                "when": "editorLangId == xlang"
            },
            {
                "command": "xlang.run",
                "key": "ctrl+f5",
                "when": "editorLangId == xlang"
            },
            {
                "command": "xlang.compileRun",
                "key": "f5",
                "when": "editorLangId == xlang"
            }
        ],
        "menus": {
            "editor/context": [
                {
                    "command": "xlang.compile",
                    "group": "xlang@1",
                    "when": "resourceLangId == xlang"
                },
                {
                    "command": "xlang.run",
                    "group": "xlang@2",
                    "when": "resourceLangId == xlang"
                },
                {
                    "command": "xlang.compileRun",
                    "group": "xlang@3",
                    "when": "resourceLangId == xlang"
                }
            ]
        },
        "configuration": {
            "title": "XLang",
            "properties": {
                "xlang.compilerPath": {
                    "type": "string",
                    "default": "xlangc",
                    "description": "Path to XLang compiler executable"
                },
                "xlang.compilerArgs": {
                    "type": "array",
                    "default": [],
                    "description": "Additional arguments to pass to the compiler"
                },
                "xlang.runInTerminal": {
                    "type": "boolean",
                    "default": true,
                    "description": "Run compiled programs in the integrated terminal"
                },
                "xlang.formatOnSave": {
                    "type": "boolean",
                    "default": true,
                    "description": "Format XLang files automatically on save"
                },
                "xlang.outputDirectory": {
                    "type": "string",
                    "default": ".",
                    "description": "Directory for compiled executables"
                }
            }
        }
    }
}