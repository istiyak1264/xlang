{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "scopeName": "source.xlang",
    "name": "XLang",
    "fileTypes": ["x", "xl", "xlang"],
    "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#keywords-control" },
        { "include": "#keywords-other" },
        { "include": "#types" },
        { "include": "#constants" },
        { "include": "#functions" },
        { "include": "#numbers" },
        { "include": "#operators" },
        { "include": "#punctuation" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.xlang",
                    "match": "//.*$"
                },
                {
                    "name": "comment.block.xlang",
                    "begin": "/\\*",
                    "end": "\\*/",
                    "beginCaptures": { "0": { "name": "punctuation.definition.comment.xlang" } },
                    "endCaptures":   { "0": { "name": "punctuation.definition.comment.xlang" } }
                }
            ]
        },
        "strings": {
            "name": "string.quoted.double.xlang",
            "begin": "\"",
            "end": "\"",
            "patterns": [
                {
                    "name": "constant.character.escape.xlang",
                    "match": "\\\\(?:[ntr\"\\\\])"
                }
            ]
        },
        "keywords-control": {
            "name": "keyword.control.xlang",
            "match": "\\b(if|else\\s+if|else|while|for|switch|case|default|break|done|skip|return)\\b"
        },
        "keywords-other": {
            "name": "keyword.other.xlang",
            "match": "\\b(function|import|output|input)\\b"
        },
        "types": {
            "name": "storage.type.xlang",
            "match": "\\b(int|float|double|string|array|void)\\b"
        },
        "constants": {
            "name": "constant.language.xlang",
            "match": "\\b(true|false|null|nil)\\b"
        },
        "functions": {
            "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
            "captures": {
                "1": { "name": "entity.name.function.xlang" }
            }
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.float.xlang",
                    "match": "\\b\\d+\\.\\d+\\b"
                },
                {
                    "name": "constant.numeric.integer.xlang",
                    "match": "\\b\\d+\\b"
                }
            ]
        },
        "operators": {
            "name": "keyword.operator.xlang",
            "match": ":=|\\+\\+|--|==|!=|<=|>=|&&|\\|\\||[+\\-*/%<>!=^]"
        },
        "punctuation": {
            "name": "punctuation.xlang",
            "match": "[(){}\\[\\],;:\\.]"
        }
    }
}